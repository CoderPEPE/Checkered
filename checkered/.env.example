# ============================================================
# Checkered — Environment Variables
# Copy this to .env and fill in your values
# NEVER commit the .env file to git!
# ============================================================

# Your wallet private key (for deploying contracts)
# Export from MetaMask: Account Details → Show Private Key
DEPLOYER_PRIVATE_KEY=0x_your_private_key_here

# Alchemy RPC URL for Base Sepolia
# Get from: https://www.alchemy.com (free account)
BASE_RPC_URL=https://base-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# Base mainnet RPC (for production deployment later)
BASE_MAINNET_RPC_URL=https://base-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# BaseScan API key (for contract verification)
# Get from: https://basescan.org → API Keys
BASESCAN_API_KEY=your_basescan_api_key

# Treasury wallet address (receives platform fees)
TREASURY_ADDRESS=0x_your_wallet_address

# Oracle wallet address (submits race results on-chain)
ORACLE_ADDRESS=0x_your_wallet_address

# Deployed contract addresses (filled after deployment)
USDC_ADDRESS=
TOURNAMENT_CONTRACT_ADDRESS=

# ============================================================
# Checkered Oracle Backend — Environment Variables
# Copy this to .env and fill in your values
# ============================================================

PORT=3001
NODE_ENV=development

# Base Sepolia RPC URL
BASE_RPC_URL=https://base-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# Deployed contract addresses
TOURNAMENT_CONTRACT_ADDRESS=0x_tournament_contract_address
USDC_ADDRESS=0x_usdc_contract_address

# Oracle wallet private key (must have ORACLE_ROLE on the contract)
ORACLE_PRIVATE_KEY=0x_your_oracle_private_key

# Admin API key for protected endpoints
ADMIN_API_KEY=change-this-to-a-random-string

# iRacing credentials
IRACING_EMAIL=your@email.com
IRACING_PASSWORD=your_iracing_password

# Set to true for testing without real iRacing API
IRACING_MOCK_MODE=true

# How often to poll for race results (milliseconds)
POLL_INTERVAL=30000

# ---- Auto-tournament creation from iRacing league ----
# League ID to watch (132296 = your league)
AUTO_CREATE_LEAGUE_ID=132296
# Pin to a specific season ID, or leave 0 to auto-discover active seasons
AUTO_CREATE_SEASON_ID=0
# Entry fee in whole CHEX tokens (100 = 100 CHEX)
AUTO_CREATE_ENTRY_FEE=100
# Max players per auto-created tournament
AUTO_CREATE_MAX_PLAYERS=50
# How often to check for new sessions (milliseconds, default 1 hour)
AUTO_CREATE_INTERVAL=3600000
